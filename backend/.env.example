# 复制为 .env 后按需修改；不要提交 .env 到版本库

APP_ENV=development

# 必填：生产环境务必改为随机强密钥
SECRET_KEY=change-me-please

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL（异步驱动 asyncpg）
DATABASE_URL=postgresql+asyncpg://xblog:你的密码@localhost:5432/xblog

# CORS（开发时 Next.js 默认端口）
CORS_ORIGINS=http://localhost:3000

# Cookie（生产改为 true 与你的域名）
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ISR revalidate（与 frontend/.env 中 REVALIDATE_SECRET 一致）
REVALIDATE_SECRET=change-me-revalidate
REVALIDATE_URL=http://localhost:3000/api/revalidate

# 用户上传目录（Skill 包等，相对 backend/ 根目录）
UPLOAD_DIR=uploads

# --- OAuth（GitHub / 微信开放平台）---
FRONTEND_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- 短信验证码（开发默认 dev，验证码输出到 backend 日志）---
SMS_PROVIDER=dev
SMS_CODE_EXPIRE_MINUTES=5
SMS_SEND_INTERVAL_SECONDS=60
# SMS_PROVIDER=aliyun 时需配置：
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
PASSWORD_RESET_EXPIRE_MINUTES=60
