# 复制为 .env 后按需修改；不要提交 .env 到版本库
APP_ENV=development

# 必填：生产环境务必改为随机强密钥
SECRET_KEY=change-me-please

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL（异步驱动 asyncpg）
DATABASE_URL=postgresql+asyncpg://xblog:你的密码@localhost:5432/xblog

# CORS（开发时 Next.js 默认端口）
CORS_ORIGINS=http://localhost:3000

# Cookie（生产改为 true 与你的域名）
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ISR revalidate（与 frontend REVALIDATE_SECRET 一致）
REVALIDATE_SECRET=change-me-revalidate
REVALIDATE_URL=http://localhost:3000/api/revalidate
