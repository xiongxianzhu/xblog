# =============================================================================
# xblog Web（frontend）
# 完整规则见仓库根目录 ../.gitignore
# 以下为相对本目录的路径写法（leading / 表示仅 frontend 根下）
# =============================================================================

/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/.next/
/out/
/build
.turbo/

/coverage

# 本地环境（复制 .env.example → .env，勿提交 .env）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
!.env.example

*.tsbuildinfo
next-env.d.ts
.eslintcache

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

.vercel
*.pem

.DS_Store
.idea/
.vscode/
