# 复制为 .env.local 后按需修改；勿提交 .env.local

# 后端 API（服务端 fetch 与 /api rewrite）
BACKEND_URL=http://localhost:8000

# 站点绝对 URL（sitemap、RSS、Open Graph）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ISR 回调（与 backend/.env 中 REVALIDATE_SECRET 一致）
REVALIDATE_SECRET=change-me-revalidate

# --- Giscus 评论（https://giscus.app 生成配置）---
# 仓库需启用 GitHub Discussions
NEXT_PUBLIC_GISCUS_REPO=your-org/your-repo
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
# 可选：pathname | url | title | og:title
# NEXT_PUBLIC_GISCUS_MAPPING=pathname
# NEXT_PUBLIC_GISCUS_INPUT_POSITION=top
# NEXT_PUBLIC_GISCUS_THEME=catppuccin_mocha
