# =============================================================================
# xblog Monorepo — 根目录 .gitignore（权威汇总）
# backend/.gitignore、frontend/.gitignore 为子目录补充，规则与此保持一致
# =============================================================================

# =============================================================================
# 通用 — 操作系统 / IDE / 日志 / 临时文件
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~

*.log
logs/
tmp/
temp/
*.tmp
*.bak

# =============================================================================
# 通用 — 环境与密钥（任意目录均生效）
# =============================================================================
.env
.env.*
.env.local
.env.*.local
!.env.example

# =============================================================================
# 通用 — 测试与覆盖率
# =============================================================================
coverage/
.nyc_output/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
hypothesis/

# =============================================================================
# 后端 — Python / uv / FastAPI（backend/ 及仓库内任意 Python 产物）
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec

.venv/
venv/
ENV/

.pytest_cache/
.ruff_cache/
.mypy_cache/

*.db
*.sqlite
*.sqlite3

# 用户上传（仅保留 .gitkeep 占位）
backend/uploads/*
!backend/uploads/.gitkeep

# =============================================================================
# 前端 — Node / Next.js（frontend/ 及仓库内同类产物）
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.next/
out/
frontend/build/
.turbo/

*.tsbuildinfo
next-env.d.ts
.eslintcache

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

.vercel
*.pem
